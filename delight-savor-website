  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}
.eyebrow::before, .eyebrow::after {
  content: '';
  display: block;
  width: 2rem;
  height: 1px;
  background: var(--gold);
  flex-shrink: 0;
}
.eyebrow.light { color: rgba(255,255,255,0.6); }
.eyebrow.light::before, .eyebrow.light::after { background: rgba(255,255,255,0.3); }

em { font-style: italic; color: var(--gold); }

/* ── Buttons ── */
.btn {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.85rem 1.75rem;
  border: 1.5px solid currentColor;
  cursor: pointer;
  transition: var(--transition);
}
.btn-primary {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--white);
}
.btn-primary:hover { background: var(--amber); border-color: var(--amber); }

.btn-secondary {
  background: transparent;
  border-color: var(--white);
  color: var(--white);
}
.btn-secondary:hover { background: rgba(255,255,255,0.1); }

.btn-outline {
  background: transparent;
  border-color: var(--slate);
  color: var(--slate);
}
.btn-outline:hover { background: var(--slate); color: var(--white); }

.btn-gold {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--white);
}
.btn-gold:hover { background: var(--amber); border-color: var(--amber); }

/* ── Layout Helpers ── */
.section-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: var(--section-pad);
}

.section-header {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 3.5rem;
}
.section-header.left-align { text-align: left; margin: 0 0 2rem; }

.section-title {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--near-black);
  margin-bottom: 1.25rem;
}

.section-intro {
  font-size: 1.15rem;
  color: var(--slate);
  line-height: 1.8;
  font-style: italic;
}

.section-cta {
  text-align: center;
  margin-top: 3rem;
}

/* ============================================================
   NAV
   ============================================================ */
.site-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--green-dark);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.nav-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  height: 64px;
}

.nav-brand {
  display: flex;
  flex-direction: column;
  line-height: 1.2;
  flex-shrink: 0;
}
.nav-brand .brand-name {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--white);
  font-weight: 400;
}
.nav-brand .brand-tagline {
  font-family: var(--font-ui);
  font-size: 0.55rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold-light);
}

.nav-social {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  margin-left: 0.5rem;
}
.nav-social a {
  color: rgba(255,255,255,0.5);
  font-size: 0.8rem;
  transition: color 0.2s;
}
.nav-social a:hover { color: var(--gold-light); }

.nav-links {
  display: flex;
  gap: 0;
  align-items: center;
  margin-left: auto;
  flex-wrap: wrap;
}
.nav-links a {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.75);
  padding: 0.4rem 0.7rem;
  transition: color 0.2s;
  white-space: nowrap;
}
.nav-links a:hover { color: var(--gold-light); }

.nav-cta {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--gold);
  color: var(--white) !important;
  padding: 0.6rem 1.1rem;
  flex-shrink: 0;
  transition: background 0.2s;
}
.nav-cta:hover { background: var(--amber); }

/* ============================================================
   HERO
   ============================================================ */
.hero {
  background: var(--green-dark);
  background-image:
    radial-gradient(ellipse at 70% 50%, rgba(74,103,65,0.4) 0%, transparent 60%),
    radial-gradient(ellipse at 20% 80%, rgba(45,74,45,0.6) 0%, transparent 50%);
  min-height: 540px;
  display: flex;
  flex-direction: column;
}

.hero-inner {
  flex: 1;
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 5rem 2rem 4rem;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
  width: 100%;
}

.hero-content { max-width: 520px; }

.hero-headline {
  font-size: clamp(2.5rem, 5vw, 3.75rem);
  color: var(--white);
  margin-bottom: 1.25rem;
  line-height: 1.1;
}
.hero-headline em { color: var(--gold-light); }

.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.8);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 420px;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* Book Mockup */
.hero-book {
  display: flex;
  align-items: center;
  justify-content: center;
}

.book-mockup {
  width: 180px;
  background: var(--white);
  box-shadow: -8px 8px 32px rgba(0,0,0,0.35), 2px 2px 0 rgba(0,0,0,0.1);
  border-left: 6px solid var(--cream-dark);
  padding: 1rem;
  transform: rotate(-1deg);
}
.book-header {
  font-family: var(--font-ui);
  font-size: 0.5rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate-light);
  border-bottom: 1px solid var(--cream-dark);
  padding-bottom: 0.5rem;
  margin-bottom: 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}
.book-series { font-style: italic; }
.book-image {
  width: 100%;
  height: 110px;
  background: linear-gradient(160deg, #4a2020 0%, #1a0a0a 40%, #2d1a0a 70%, #3d2010 100%);
  margin-bottom: 0.75rem;
}
.book-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  text-align: center;
  color: var(--near-black);
  letter-spacing: 0.05em;
}

/* New Here Strip */
.new-here-strip {
  background: var(--gold);
  padding: 0.85rem 2rem;
}
.new-here-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.new-here-label {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--white);
  flex-shrink: 0;
}
.new-here-steps {
  display: flex;
  gap: 0;
  align-items: center;
  flex-wrap: wrap;
  flex: 1;
}
.new-here-step {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-ui);
  font-size: 0.7rem;
  color: rgba(255,255,255,0.9);
}
.new-here-step:not(:last-child)::after {
  content: '→';
  margin: 0 0.75rem;
  color: rgba(255,255,255,0.5);
}
.step-num {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  color: var(--white);
  font-size: 0.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.new-here-step a { color: var(--white); text-decoration: underline; }

/* ============================================================
   PHILOSOPHY
   ============================================================ */
.philosophy { background: var(--cream); }

.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 1px solid var(--cream-dark);
}

.pillar {
  padding: 2rem 1.75rem;
  border: 1px solid var(--cream-dark);
  position: relative;
}

.pillar-numeral {
  font-family: var(--font-display);
  font-size: 1.5rem;
  color: var(--cream-dark);
  font-weight: 300;
  margin-bottom: 0.5rem;
}

.pillar-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-style: italic;
  color: var(--near-black);
  margin-bottom: 0.6rem;
  font-weight: 500;
}

.pillar-body {
  font-size: 0.95rem;
  color: var(--slate);
  line-height: 1.7;
}

.philosophy-cta {
  text-align: center;
  margin-top: 3rem;
}

.pull-quote-band {
  background: var(--green-dark);
  padding: 2.5rem 2rem;
}
.pull-quote-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
}
.pull-quote-text {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  font-style: italic;
  color: var(--white);
  flex: 1;
}
.pull-quote-text em { color: var(--gold-light); font-style: normal; }
.pull-quote-label {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  white-space: nowrap;
}

/* ============================================================
   CURRICULUM
   ============================================================ */
.curriculum { background: var(--white); }

.curriculum-bundle {
  border: 1px solid var(--cream-dark);
  padding: 2.5rem;
  margin-bottom: 2rem;
  position: relative;
}

.bundle-badge {
  display: inline-block;
  background: var(--gold);
  color: var(--white);
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.3rem 0.75rem;
  margin-bottom: 0.75rem;
}

.bundle-label {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--slate-light);
  margin-bottom: 0.4rem;
}

.bundle-title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: var(--near-black);
  margin-bottom: 0.25rem;
}

.bundle-subtitle {
  font-style: italic;
  color: var(--slate-light);
  font-size: 0.95rem;
  margin-bottom: 1rem;
}

.bundle-desc {
  color: var(--slate);
  margin-bottom: 1.25rem;
  max-width: 680px;
}

.bundle-includes {
  list-style: none;
  margin-bottom: 1.5rem;
}
.bundle-includes li {
  font-size: 0.95rem;
  color: var(--slate);
  padding: 0.2rem 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.bundle-includes li::before {
  content: '·';
  color: var(--gold);
  font-size: 1.2rem;
}

.version-tabs {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.version-tab {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate);
  border: 1px solid var(--cream-dark);
  padding: 0.4rem 0.85rem;
  background: var(--cream);
}

.curriculum-units {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border: 1px solid var(--cream-dark);
}

.unit-card {
  padding: 2.5rem;
  border: 1px solid var(--cream-dark);
}

.unit-semester {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--slate-light);
  margin-bottom: 0.5rem;
}

.unit-title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  color: var(--near-black);
  margin-bottom: 0.2rem;
}

.unit-author {
  font-style: italic;
  color: var(--slate-light);
  font-size: 0.95rem;
  margin-bottom: 1rem;
}

.unit-desc {
  color: var(--slate);
  font-size: 0.95rem;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.unit-includes {
  list-style: none;
  margin-bottom: 1.5rem;
}
.unit-includes li {
  font-size: 0.9rem;
  color: var(--slate);
  padding: 0.15rem 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.unit-includes li::before { content: '·'; color: var(--gold); font-size: 1.2rem; }

/* ============================================================
   ABOUT STRIP
   ============================================================ */
.about-strip {
  background: var(--cream);
  border-top: 1px solid var(--cream-dark);
  border-bottom: 1px solid var(--cream-dark);
  padding: 3rem 2rem;
}
.about-strip-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.25rem;
}
.about-tagline {
  font-family: var(--font-display);
  font-size: clamp(1rem, 2vw, 1.25rem);
  font-style: italic;
  color: var(--slate);
}
.about-credentials {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: center;
}
.credential-tag {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate);
  border: 1px solid var(--cream-dark);
  padding: 0.35rem 0.85rem;
  background: var(--white);
}

/* ============================================================
   TESTIMONIALS
   ============================================================ */
.testimonials { background: var(--cream); }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.testimonial-card {
  background: var(--white);
  border: 1px solid var(--cream-dark);
  padding: 2rem 1.75rem;
  position: relative;
}

.testimonial-mark {
  font-family: var(--font-display);
  font-size: 3rem;
  color: var(--cream-dark);
  line-height: 1;
  margin-bottom: 0.5rem;
}

.testimonial-quote {
  font-style: italic;
  font-size: 1rem;
  color: var(--near-black);
  line-height: 1.75;
  margin-bottom: 1.25rem;
}

.testimonial-role {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--slate-light);
}

.testimonial-context {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  color: var(--gold);
  margin-top: 0.2rem;
}

/* ============================================================
   CHARLOTTE MASON
   ============================================================ */
.cm-section { background: var(--white); }

.cm-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.cm-paragraphs p {
  color: var(--slate);
  line-height: 1.85;
  margin-bottom: 1.25rem;
  font-size: 1rem;
}

.cm-quote-box {
  border-left: 3px solid var(--green);
  padding: 1.5rem 1.5rem 1.5rem 1.75rem;
  background: var(--cream);
  margin-bottom: 1.5rem;
}
.cm-quote-text {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.05rem;
  color: var(--near-black);
  line-height: 1.7;
  margin-bottom: 0.75rem;
}
.cm-quote-attr {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--slate-light);
}

.cm-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.cm-tag {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate);
  border: 1px solid var(--cream-dark);
  padding: 0.3rem 0.7rem;
  background: var(--cream);
}

/* ============================================================
   TEACHER'S NOTEBOOK PREVIEW
   ============================================================ */
.notebook-preview { background: var(--cream); }

.notebook-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.notebook-card {
  background: var(--white);
  border: 1px solid var(--cream-dark);
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
}

.notebook-card-category {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--slate-light);
  border: 1px solid var(--cream-dark);
  padding: 0.25rem 0.6rem;
  display: inline-block;
  margin-bottom: 1rem;
  align-self: flex-start;
}

.notebook-card-title {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.1rem;
  color: var(--near-black);
  line-height: 1.35;
  margin-bottom: 0.75rem;
  flex: 1;
}

.notebook-card-summary {
  font-size: 0.9rem;
  color: var(--slate);
  line-height: 1.65;
  margin-bottom: 1.25rem;
}

.notebook-card-link {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--green);
  display: flex;
  align-items: center;
  gap: 0.4rem;
  transition: gap 0.2s;
}
.notebook-card-link:hover { gap: 0.7rem; }

/* ============================================================
   FAQ
   ============================================================ */
.faq { background: var(--white); }

.faq-list {
  max-width: 780px;
  margin: 0 auto;
}

.faq-item {
  border-bottom: 1px solid var(--cream-dark);
}

.faq-question {
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.05rem;
  color: var(--slate);
  padding: 1.4rem 2.5rem 1.4rem 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: color 0.2s;
  position: relative;
}
.faq-question:hover { color: var(--near-black); }
.faq-question.open { color: var(--near-black); }

.faq-icon {
  width: 20px;
  height: 20px;
  position: relative;
  flex-shrink: 0;
  color: var(--gold);
}
.faq-icon::before, .faq-icon::after {
  content: '';
  position: absolute;
  background: currentColor;
  transition: transform 0.3s, opacity 0.3s;
}
.faq-icon::before { width: 12px; height: 1px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
.faq-icon::after  { width: 1px; height: 12px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
.faq-question.open .faq-icon::after { transform: translate(-50%,-50%) rotate(90deg); opacity: 0; }

.faq-answer {
  font-size: 1rem;
  color: var(--slate);
  line-height: 1.8;
  padding: 0 1rem 1.5rem 0;
  display: none;
}
.faq-answer.open { display: block; }

/* ============================================================
   COMING SOON
   ============================================================ */
.coming-soon { background: var(--cream); }

.coming-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.coming-card {
  background: var(--white);
  border: 1px solid var(--cream-dark);
  padding: 1.75rem;
}

.coming-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0.5rem;
}

.coming-category {
  font-family: var(--font-ui);
  font-size: 0.55rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--slate-light);
}

.coming-badge {
  font-family: var(--font-ui);
  font-size: 0.55rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate-light);
  border: 1px solid var(--cream-dark);
  padding: 0.2rem 0.5rem;
}

.coming-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  color: var(--near-black);
  margin-bottom: 0.2rem;
}

.coming-subtitle {
  font-style: italic;
  color: var(--slate-light);
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

.coming-cover {
  width: 100%;
  height: 100px;
  background: linear-gradient(135deg, var(--green-light) 0%, var(--cream-dark) 100%);
  margin-bottom: 1rem;
  border: 1px solid var(--cream-dark);
  display: flex;
  align-items: center;
  justify-content: center;
}
.coming-cover-inner {
  font-family: var(--font-ui);
  font-size: 0.5rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate-light);
  text-align: center;
}

.coming-desc {
  font-size: 0.9rem;
  color: var(--slate);
  line-height: 1.65;
  margin-bottom: 0.75rem;
}

.coming-versions {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  color: var(--slate-light);
}

/* ============================================================
   JOURNAL BAND
   ============================================================ */
.journal-band {
