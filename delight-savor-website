{
  "eyebrow": "What We Believe",
  "headline": {
    "plain": "A Different Kind of ",
    "italic": "Literary Education"
  },
  "intro": "Literature is the main dish — not a side. Every feast has a centerpiece, and for us it is the text: the reading, the thinking, the conversation it opens. From that center, everything else grows — writing, grammar, philosophy, rhetoric, the habits of mind that serve a student in any field they choose.",
  "pillars": [
    {
      "numeral": "I",
      "title": "Narration First, Always",
      "body": "Before analysis comes comprehension, and before comprehension comes attention. The work begins here."
    },
    {
      "numeral": "II",
      "title": "Writing Grown from the Text",
      "body": "Craft is learned in context, not in a vacuum. Two or three principles per term, drawn directly from the literature."
    },
    {
      "numeral": "III",
      "title": "The Great Conversation",
      "body": "Aristotle, Augustine, Rousseau — not as separate lessons, but as voices already present in the text."
    },
    {
      "numeral": "IV",
      "title": "Direction Without Busywork",
      "body": "Enough structure that you never feel lost. Enough freedom to make it yours."
    },
    {
      "numeral": "V",
      "title": "Ideas That Resonate",
      "body": "Love, ambition, justice, beauty — the things that form a person, not just prepare them for a test."
    },
    {
      "numeral": "VI",
      "title": "Habits for Any Future",
      "body": "Close reading, careful thinking, articulate expression — habits that serve a student in any field they choose."
    }
  ],
  "pull_quote": {
    "text": "Finally — something I can use for my high school student. Enough guidance that I'm not lost, enough freedom that it still feels like ours.",
    "highlight_word": "ours",
    "label": "What We Want Every Mama to Feel"
  },
