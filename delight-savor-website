  },
  "filter_categories": [
    { "label": "All Notes", "value": "all", "default": true },
    { "label": "Narration", "value": "narration" },
    { "label": "Discussion", "value": "discussion" },
    { "label": "Classroom Management", "value": "classroom-management" },
    { "label": "Pacing & Planning", "value": "pacing-planning" },
